{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
    },
    "plugins": [
      {
        "name": "gql.tada/ts-plugin",
        "schema": "http://localhost:3001/graphql",
        "tadaOutputLocation": "./graphql-env.d.ts",
      },
    ],
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
}
